<view class="toolbox-page">
  <view class="toolbox-hero">
    <view>
      <text class="hero-kicker">爱木长诗的小工具箱</text>
      <text class="hero-title">今天想做点什么？</text>
      <text class="hero-sub">{{currentDate}} · {{weatherDesc}}</text>
    </view>
    <view class="hero-badge">
      <text>木</text>
      <text>诗</text>
    </view>
  </view>

  <view class="search-panel">
    <input class="search-input"
           placeholder="搜：天气、美食、树洞、AI、纪念日"
           value="{{searchValue}}"
           bindinput="onSearchInput"
           confirm-type="search"
           bindconfirm="onSearch" />
    <text wx:if="{{searchValue}}" class="search-clear" bindtap="clearSearch">清空</text>
  </view>

  <scroll-view class="group-tabs" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="tab-track">
      <view class="tab {{activeGroupKey === item.key ? 'active' : ''}}"
            wx:for="{{groups}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="selectGroup">
        <text>{{item.name}}</text>
      </view>
    </view>
  </scroll-view>

  <view class="result-line">
    <text>{{resultText}}</text>
  </view>

  <swiper wx:if="{{!searchMode}}"
          class="group-swiper"
          current="{{activeGroupIndex}}"
          bindchange="onGroupSwiperChange"
          duration="260">
    <swiper-item wx:for="{{groups}}" wx:key="key">
      <swiper class="tool-swiper"
              current="{{activeToolPage}}"
              bindchange="onToolPageChange"
              duration="220">
        <swiper-item wx:for="{{toolPages}}" wx:key="index">
          <view class="tool-grid">
            <view wx:if="{{item.length === 0}}" class="empty-box">{{emptyText}}</view>
            <view class="tool-card {{tool.status === 'later' ? 'is-later' : ''}}"
                  wx:for="{{item}}"
                  wx:for-item="tool"
                  wx:key="key"
                  data-route="{{tool.route}}"
                  data-tabbar="{{tool.tabbar}}"
                  bindtap="openTool">
              <view class="tool-icon">{{tool.icon}}</view>
              <view class="tool-main">
                <view class="tool-title-row">
                  <text class="tool-name">{{tool.name}}</text>
                  <text wx:if="{{tool.status === 'later'}}" class="status-tag">后续</text>
                </view>
                <text class="tool-desc">{{tool.desc}}</text>
              </view>
            </view>
          </view>
        </swiper-item>
      </swiper>
    </swiper-item>
  </swiper>

  <swiper wx:else
          class="tool-swiper search-swiper"
          current="{{activeToolPage}}"
          bindchange="onToolPageChange"
          duration="220">
    <swiper-item wx:for="{{toolPages}}" wx:key="index">
      <view class="tool-grid">
        <view wx:if="{{item.length === 0}}" class="empty-box">{{emptyText}}</view>
        <view class="tool-card {{tool.status === 'later' ? 'is-later' : ''}}"
              wx:for="{{item}}"
              wx:for-item="tool"
              wx:key="key"
              data-route="{{tool.route}}"
              data-tabbar="{{tool.tabbar}}"
              bindtap="openTool">
          <view class="tool-icon">{{tool.icon}}</view>
          <view class="tool-main">
            <view class="tool-title-row">
              <text class="tool-name">{{tool.name}}</text>
              <text wx:if="{{tool.status === 'later'}}" class="status-tag">后续</text>
            </view>
            <text class="tool-desc">{{tool.desc}}</text>
          </view>
        </view>
      </view>
    </swiper-item>
  </swiper>

  <view class="pagination" wx:if="{{pageDots.length > 1}}">
    <view class="dot {{activeToolPage === item ? 'active' : ''}}" wx:for="{{pageDots}}" wx:key="*this"></view>
  </view>

  <view class="weather-card">
    <view class="weather-copy">
      <text class="weather-title">远方天气卡片</text>
      <text class="weather-desc">可以看自己的天气，也可以看 Ta 主动同步的位置。没有位置时，会温柔地等一等。</text>
    </view>
    <button class="weather-btn" bindtap="checkWeatherDetail">打开天气卡片</button>
  </view>
</view>
