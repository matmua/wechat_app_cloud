/* pages/home/home.wxss */
.container {
  background: linear-gradient(135deg, #a1b0f1 0%, #764ba2 100%);
  margin: 0; padding: 0; border: none;
}

/* 主标题区域 */
.main-header {
  padding: 10rpx 0rpx 30rpx 40rpx;
  padding-left: 80rpx;
  height: 210rpx;
  width: 100%;
  margin: 0;
  /* 添加背景以覆盖下方内容 */
  background: linear-gradient(135deg, #a1b0f1 0%, #764ba2 100%);
}

.title-section {
  margin-top: 15rpx; /* 顶部对齐 */
  margin-bottom: 30rpx;
}

.main-title {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
  margin-right: 20rpx;
}

.sub-title {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 50rpx;
  /* 减小上下内边距解决"太胖"问题 */
  padding: 15rpx 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
  /* 关键：限制宽度并包含内边距计算 */
  width: 93%;
  box-sizing: border-box;
}

/* 地址选择器容器：强制内部元素水平排列 + 不被挤压 */
.location-picker {
  display: flex; /* 水平排列子元素 */
  align-items: center; /* 垂直居中对齐 */
  white-space: nowrap; /* 禁止容器内元素换行 */
  margin-right: 15rpx; /* 与搜索框间距 */
  min-width: 120rpx; /* 增大最小宽度，确保文本+图标有足够空间 */
  flex-shrink: 0; /* 关键！禁止父容器被 search-input 挤压（之前缺失） */
  padding: 5rpx 0; /* 可选：增加垂直内边距，避免内容贴边 */
}

/* 地址文本：确保单行显示 */
.picker-text {
  font-size: 26rpx;
  color: #333;
  margin-right: 8rpx; /* 文本与图标之间的间距 */
  /* 禁止文本换行（核心：防止文本过长挤到图标下方） */
  white-space: nowrap;
  /* 文本过长时显示省略号，避免撑开容器 */
  overflow: hidden;
  text-overflow: ellipsis;
}

/* 下拉图标：与文本精准对齐 */
.dropdown-icon {
  width: 20rpx;
  height: 20rpx;
  vertical-align: middle; /* 与文本中线对齐 */
  display: inline-block; /* 确保图标为行内元素，不独占一行 */
  margin-top: -2rpx; /* 可选：微调垂直位置，视觉更居中 */
}


.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #666;
  margin: 0 20rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
}

/* 功能菜单网格 */
.menu-grid {
  background: white;
  margin: 10rpx 30rpx;
  border-radius: 20rpx;
  padding: 40rpx 20rpx 20rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.1);
}

.menu-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 40rpx;
}

.menu-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 120rpx;
  padding: 20rpx 10rpx;
  border-radius: 16rpx;
  transition: all 0.3s ease;
}

.menu-item:active {
  background: #f5f5f5;
  transform: scale(0.95);
}

.menu-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 16rpx;
}

.menu-text {
  font-size: 24rpx;
  color: #333;
  text-align: center;
  line-height: 1.2;
}

/* 分页指示器 */
.pagination {
  display: flex;
  justify-content: center;
  margin: 30rpx 0 40rpx;
  gap: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.4);
  transition: all 0.3s ease;
}

.dot.active {
  background: white;
  width: 32rpx;
  border-radius: 8rpx;
}

/* 天气提醒卡片 */
.weather-card {
  margin: 0 30rpx 30rpx;
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #fecfef 100%);
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.15);
}

.weather-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.weather-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.weather-date {
  font-size: 24rpx;
  color: #666;
}

.weather-content {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.weather-info {
  flex: 1;
}

.weather-main-text {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.weather-sub-text {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.weather-suggestion {
  margin-top: 20rpx;
}

.weather-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 25rpx;
  padding: 16rpx 32rpx;
  font-size: 26rpx;
  box-shadow: 0 4rpx 15rpx rgba(102, 126, 234, 0.4);
}

.weather-btn:active {
  transform: scale(0.95);
}

.weather-image {
  width: 120rpx;
  height: 120rpx;
  margin-left: 20rpx;
}