page {
  background: #f7f2ec;
}

.toolbox-page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  color: #2e2a28;
}

.toolbox-hero {
  display: flex;
  justify-content: space-between;
  gap: 22rpx;
  padding: 34rpx 30rpx;
  border-radius: 34rpx;
  background: #fffdf8;
  border: 1rpx solid #eadcc9;
  box-shadow: 0 20rpx 42rpx rgba(98, 72, 45, 0.1);
}

.hero-kicker,
.hero-title,
.hero-sub,
.result-line text,
.tool-name,
.tool-desc,
.weather-title,
.weather-desc {
  display: block;
}

.hero-kicker {
  color: #b56d45;
  font-size: 22rpx;
  font-weight: 800;
}

.hero-title {
  margin-top: 10rpx;
  font-size: 48rpx;
  line-height: 1.12;
  font-weight: 900;
  letter-spacing: 0;
}

.hero-sub {
  margin-top: 12rpx;
  color: #7b6d63;
  font-size: 25rpx;
}

.hero-badge {
  width: 112rpx;
  min-width: 112rpx;
  height: 144rpx;
  border-radius: 56rpx 56rpx 30rpx 30rpx;
  background: #2e2a28;
  color: #f7e4bb;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 34rpx;
  font-weight: 900;
  box-shadow: inset 0 -10rpx 0 rgba(255,255,255,0.08);
}

.search-panel {
  margin-top: 24rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  border-radius: 26rpx;
  background: #ffffff;
  border: 1rpx solid #eadcc9;
}

.search-input {
  flex: 1;
  min-width: 0;
  height: 56rpx;
  font-size: 26rpx;
  color: #2e2a28;
}

.search-clear {
  color: #b56d45;
  font-size: 24rpx;
  font-weight: 800;
}

.group-tabs {
  margin: 24rpx -28rpx 0;
  white-space: nowrap;
}

.tab-track {
  display: block;
  padding: 0 28rpx 4rpx;
  white-space: nowrap;
}

.tab {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  min-width: 132rpx;
  box-sizing: border-box;
  margin-right: 14rpx;
  padding: 16rpx 24rpx;
  border-radius: 999rpx;
  background: #ffffff;
  border: 1rpx solid #eadcc9;
  color: #7b6d63;
  font-size: 25rpx;
  font-weight: 800;
  text-align: center;
  white-space: nowrap;
}

.tab.active {
  background: #2e2a28;
  color: #fff4df;
  border-color: #2e2a28;
}

.result-line {
  margin: 20rpx 4rpx 14rpx;
  color: #8a7d72;
  font-size: 24rpx;
}

.group-swiper {
  height: 650rpx;
}

.tool-swiper {
  height: 650rpx;
}

.search-swiper {
  margin-top: 8rpx;
}

.tool-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
  box-sizing: border-box;
}

.tool-card {
  min-height: 176rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid #eadcc9;
  box-shadow: 0 12rpx 26rpx rgba(98, 72, 45, 0.08);
  box-sizing: border-box;
}

.tool-card:active {
  transform: scale(0.98);
}

.tool-card.is-later {
  background: #fbf8f1;
  border-style: dashed;
}

.tool-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 24rpx;
  background: #f7f2ec;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 38rpx;
  margin-bottom: 16rpx;
}

.tool-title-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.tool-name {
  flex: 1;
  min-width: 0;
  color: #2e2a28;
  font-size: 29rpx;
  font-weight: 900;
}

.tool-desc {
  margin-top: 10rpx;
  color: #7b6d63;
  font-size: 23rpx;
  line-height: 1.35;
}

.status-tag {
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #efe3d1;
  color: #8b6a47;
  font-size: 20rpx;
  font-weight: 800;
}

.empty-box {
  grid-column: 1 / span 2;
  min-height: 260rpx;
  border-radius: 30rpx;
  background: #fffdf8;
  border: 1rpx dashed #d8c6ac;
  color: #8a7d72;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
}

.pagination {
  display: flex;
  justify-content: center;
  gap: 12rpx;
  margin: 8rpx 0 22rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #d4c4b0;
}

.dot.active {
  width: 34rpx;
  background: #2e2a28;
}

.weather-card {
  margin-top: 12rpx;
  padding: 26rpx;
  border-radius: 30rpx;
  background: #dff2ff;
  border: 1rpx solid #bee3fb;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.weather-copy {
  flex: 1;
  min-width: 0;
}

.weather-title {
  color: #24547b;
  font-size: 30rpx;
  font-weight: 900;
}

.weather-desc {
  margin-top: 8rpx;
  color: #557389;
  font-size: 23rpx;
  line-height: 1.4;
}

.weather-btn {
  width: 190rpx;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 22rpx;
  background: #2f80d5;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
}
