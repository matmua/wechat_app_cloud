page {
  background: #fff6f8;
}

.page {
  min-height: 100vh;
}

.content {
  padding: 24rpx;
  box-sizing: border-box;
}

.bind-status {
  margin-bottom: 20rpx;
  padding: 18rpx 22rpx;
  border-radius: 18rpx;
  font-size: 24rpx;
  line-height: 1.5;
  color: #7a4a5b;
  background: #fff;
  border: 1rpx solid #ffd8e4;
}

.bind-status.bound {
  color: #276749;
  background: #edfdf4;
  border-color: #c6f6d5;
}

.bind-status.error {
  color: #9b2c2c;
  background: #fff5f5;
  border-color: #fed7d7;
}

.moments-frame {
  margin-bottom: 24rpx;
  padding: 22rpx;
  border-radius: 32rpx;
  background: #ffffff;
  border: 1rpx solid #ffe0ea;
  box-shadow: 0 16rpx 34rpx rgba(208, 79, 112, 0.08);
}

.hero-frame {
  background: linear-gradient(135deg, #fffdfd, #fff1f6);
}

.top-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.top-item {
  width: 150rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 6rpx solid #ffd4df;
  overflow: hidden;
  background: #fff;
  box-sizing: border-box;
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
}

.label {
  width: 150rpx;
  color: #6b4e5a;
  font-size: 24rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.heart-link {
  flex: 1;
  min-width: 0;
  padding: 18rpx 10rpx;
  border-radius: 28rpx;
  background: #fff;
  color: #c94d6c;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.heart {
  font-size: 48rpx;
  line-height: 1;
}

.bind-row {
  margin-top: 24rpx;
}

.bind-actions,
.invite-actions,
.modal-actions {
  display: flex;
  gap: 14rpx;
}

.bind-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 20rpx;
  border-radius: 999rpx;
  background: #ff6f8e;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}

.bind-btn.ghost {
  background: #fff;
  color: #b04d64;
  border: 1rpx solid #ffd8e4;
}

.bind-btn.compact {
  height: 64rpx;
  line-height: 64rpx;
  font-size: 24rpx;
}

.invite-panel {
  margin-top: 18rpx;
  padding: 18rpx;
  border-radius: 24rpx;
  background: #fff7fa;
  border: 1rpx dashed #ffc4d1;
}

.invite-label,
.invite-code,
.invite-hint,
.modal-title,
.section-title,
.section-sub,
.plan-title,
.plan-meta,
.mood-owner,
.mood-value,
.mood-note,
.quick-text {
  display: block;
}

.invite-label {
  color: #8a5c66;
  font-size: 24rpx;
  margin-bottom: 10rpx;
}

.invite-code {
  word-break: break-all;
  padding: 16rpx;
  border-radius: 18rpx;
  background: #ffffff;
  color: #d63a52;
  font-size: 24rpx;
  line-height: 1.5;
}

.invite-hint {
  margin: 12rpx 0;
  color: #9b7d88;
  font-size: 22rpx;
  line-height: 1.5;
}

.mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 50;
  background: rgba(0, 0, 0, 0.35);
  display: flex;
  align-items: flex-end;
}

.invite-modal {
  width: 100%;
  padding: 28rpx 24rpx 34rpx;
  background: #fff;
  border-radius: 30rpx 30rpx 0 0;
  box-sizing: border-box;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #2d2530;
  margin-bottom: 18rpx;
}

.invite-input {
  width: 100%;
  min-height: 170rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #f7f3f5;
  font-size: 26rpx;
  line-height: 1.5;
}

.modal-actions {
  margin-top: 20rpx;
}

.plan-frame {
  background: #fffdf8;
  border-color: #f4dfbf;
}

.mood-frame {
  background: #f8fbff;
  border-color: #d9e8ff;
}

.section-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
}

.section-title {
  color: #2d2530;
  font-size: 32rpx;
  font-weight: 900;
}

.section-sub {
  margin-top: 8rpx;
  color: #8c7b72;
  font-size: 23rpx;
  line-height: 1.35;
}

.storage-note {
  display: block;
  margin-top: 8rpx;
  color: #b06b2b;
  font-size: 22rpx;
  line-height: 1.35;
}

.more {
  color: #b56d45;
  font-size: 24rpx;
  font-weight: 800;
  white-space: nowrap;
}

.progress-track {
  margin-top: 18rpx;
  height: 14rpx;
  border-radius: 999rpx;
  background: #f3e5cf;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #f2a64f;
}

.plan-input-row {
  margin-top: 20rpx;
  display: flex;
  gap: 14rpx;
}

.plan-input {
  flex: 1;
  min-width: 0;
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: #fff7ec;
  color: #3a3029;
  font-size: 26rpx;
}

.add-plan-btn {
  width: 130rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 20rpx;
  background: #2f2a25;
  color: #fff2df;
  font-size: 26rpx;
  font-weight: 900;
}

.plan-list {
  margin-top: 18rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.plan-item {
  display: flex;
  align-items: center;
  gap: 14rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid #f2dfc6;
}

.plan-item.done {
  background: #f5fbf4;
  border-color: #cfebc8;
}

.check {
  width: 46rpx;
  height: 46rpx;
  border-radius: 50%;
  border: 3rpx solid #d9b88a;
  color: #fff;
  background: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.done .check {
  background: #68b76b;
  border-color: #68b76b;
}

.plan-main {
  flex: 1;
  min-width: 0;
}

.plan-title {
  color: #3a3029;
  font-size: 27rpx;
  font-weight: 800;
  word-break: break-word;
}

.done .plan-title {
  text-decoration: line-through;
  color: #71806d;
}

.plan-meta {
  margin-top: 6rpx;
  color: #9b8b7a;
  font-size: 22rpx;
}

.plan-delete {
  color: #c37b68;
  font-size: 23rpx;
  padding: 12rpx;
}

.soft-empty {
  margin-top: 18rpx;
  min-height: 120rpx;
  border-radius: 24rpx;
  background: #fff8ef;
  border: 1rpx dashed #e7c99f;
  color: #9b7a55;
  font-size: 25rpx;
  line-height: 1.5;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 20rpx;
  text-align: center;
}

.history-panel {
  margin-top: 20rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.history-day {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #fff;
  border: 1rpx solid #f2dfc6;
}

.history-head {
  display: flex;
  justify-content: space-between;
  color: #60422c;
  font-size: 24rpx;
  font-weight: 900;
}

.history-mini-list {
  margin-top: 10rpx;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  color: #8c7b72;
  font-size: 23rpx;
  line-height: 1.4;
}

.history-mini-list .finished {
  color: #5d9d60;
}

.mood-picker {
  margin-top: 18rpx;
  display: grid;
  grid-template-columns: repeat(5, minmax(0, 1fr));
  gap: 10rpx;
}

.mood-chip {
  min-height: 104rpx;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #d9e8ff;
  color: #44556d;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  font-size: 22rpx;
}

.mood-chip text:first-child {
  font-size: 34rpx;
}

.mood-chip.active {
  background: #2f6ed3;
  color: #ffffff;
  border-color: #2f6ed3;
}

.mood-textarea {
  margin-top: 18rpx;
  width: 100%;
  min-height: 120rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 22rpx;
  background: #ffffff;
  font-size: 25rpx;
  line-height: 1.5;
}

.word-input {
  margin-top: 14rpx;
  height: 76rpx;
  padding: 0 18rpx;
  border-radius: 20rpx;
  background: #ffffff;
  font-size: 25rpx;
}

.save-mood-btn {
  margin-top: 16rpx;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 22rpx;
  background: #2f6ed3;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
}

.mood-board {
  margin-top: 20rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.mood-card {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid #d9e8ff;
}

.mood-owner {
  color: #2f6ed3;
  font-size: 22rpx;
  font-weight: 900;
}

.mood-value {
  margin-top: 10rpx;
  color: #27364c;
  font-size: 28rpx;
  font-weight: 900;
}

.mood-note {
  margin-top: 8rpx;
  color: #6b7c93;
  font-size: 23rpx;
  line-height: 1.4;
  word-break: break-word;
}

.quick-wrapper {
  padding-bottom: 150rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 14rpx;
}

.quick-item {
  min-height: 134rpx;
  border-radius: 26rpx;
  background: #ffffff;
  border: 1rpx solid #ffe0ea;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  box-shadow: 0 10rpx 22rpx rgba(208, 79, 112, 0.07);
}

.icon-box {
  font-size: 38rpx;
  line-height: 1;
}

.quick-text {
  color: #5b4b52;
  font-size: 23rpx;
  font-weight: 800;
  text-align: center;
}

.quick-item.weather { background: #edf7ff; border-color: #cfe9ff; }
.quick-item.sock { background: #fff7ee; border-color: #f6d6b4; }
.quick-item.ai { background: #f1f5ff; border-color: #d6e2ff; }

.fab {
  position: fixed;
  right: 34rpx;
  bottom: 176rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: #ff6f8e;
  color: #ffffff;
  font-size: 56rpx;
  line-height: 90rpx;
  text-align: center;
  box-shadow: 0 16rpx 30rpx rgba(255, 111, 142, 0.42);
  z-index: 10;
}

.fab-hover {
  transform: translateY(2rpx);
  opacity: 0.95;
}
