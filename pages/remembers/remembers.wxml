<view class="page">
  <!-- 顶部安全区：仅占位，避免内容顶到状态栏 -->
  <!-- <view style="height: {{statusBarHeight}}px;"></view> -->

  <view class="content">
    <view wx:if="{{bindingMessage}}" class="bind-status {{bindingState}}">
      <text>{{bindingMessage}}</text>
    </view>

    <!-- 1. 顶部 用户-爱心-邀请（外层圆角框 + 内层卡片） -->
<view class="moments-frame">
  <view class="card card-outlined top-card no-margin">

    <!-- 左：永远显示“我”的头像 -->
    <view class="top-item" bindtap="onMe">
      <view class="avatar">
        <image class="avatar-img"
               src="{{ selfAvatarUrl || '/images/avatar_placeholder.png' }}"
               mode="aspectFill"></image>
      </view>
      <text class="label">{{ selfName || '我' }}</text>
    </view>

    <!-- 中：爱心 -->
    <view class="top-item">
      <image class="heart-img" src="/images/爱心.svg" mode="widthFix"></image>
    </view>

    <!-- 右：永远显示“我的情侣”的头像 -->
    <view class="top-item">
      <view class="avatar" bindtap="onInviteOrEditPartner">
        <image class="avatar-img"
              src="{{ partnerAvatarUrl || '/images/avatar_placeholder.png' }}"
              mode="aspectFill"></image>
      </view>
      <text class="label" bindtap="onEditPartnerName">{{ partnerName || '邀请Ta' }}</text>
    </view>


  </view>

  <!-- 未完成绑定时生成邀请 -->
  <view wx:if="{{ bindingState !== 'bound' }}" class="bind-row">
    <view class="bind-actions">
      <button class="bind-btn" loading="{{bindingLoading}}" bindtap="onInviteOrEditPartner">
        生成邀请码
      </button>
      <button class="bind-btn ghost" bindtap="openInviteInput">
        输入对方邀请码
      </button>
    </view>

    <view wx:if="{{inviteCode}}" class="invite-panel">
      <text class="invite-label">我的邀请码</text>
      <text class="invite-code" selectable="true">{{inviteCode}}</text>
      <text class="invite-hint">复制后发给Ta，Ta在“我们页”输入即可绑定。</text>
      <view class="invite-actions">
        <button class="bind-btn compact" bindtap="copyInviteCode">复制邀请码</button>
        <button class="bind-btn compact ghost" open-type="share" bindtap="onShareInviteTap">分享给Ta（可选）</button>
      </view>
    </view>
  </view>
</view>

    <view wx:if="{{showInviteInput}}" class="mask" bindtap="closeInviteInput">
      <view class="invite-modal" catchtap="noop">
        <text class="modal-title">输入对方邀请码</text>
        <textarea class="invite-input"
                  placeholder="粘贴对方发来的完整邀请码"
                  value="{{inviteInput}}"
                  bindinput="onInviteInput"
                  maxlength="260"></textarea>
        <text class="invite-hint">邀请码格式为 inviteId:token，请复制完整内容。</text>
        <view class="modal-actions">
          <button class="bind-btn ghost" bindtap="closeInviteInput" disabled="{{inviteSubmitting}}">取消</button>
          <button class="bind-btn" bindtap="confirmInviteBind" loading="{{inviteSubmitting}}">确认绑定</button>
        </view>
      </view>
    </view>


    <!-- 2. 美好瞬间（外层圆角框 + 内层卡片） -->
    <view class="moments-frame">
      <view class="card card-outlined section-card no-margin">
        <view class="section-header">
          <text class="section-title">待办提醒</text>
          <text class="more" bindtap="onMoreMoments">查看更多</text>
        </view>
        <view class="divider"></view>
        <view class="placeholder">暂无照片</view>
      </view>
    </view>

    <!-- 3. 今日心情（外层圆角框 + 内层卡片） -->
    <view class="moments-frame">
      <view class="card card-outlined section-card no-margin">
        <view class="section-header">
          <text class="section-title">今日心情</text>
        </view>
        <view class="divider"></view>
        <view class="mood-area">
          <text class="mood-empty">今天还没有记录心情~</text>
          <button class="primary-btn" bindtap="handleRecordMood">记录心情</button>
        </view>
      </view>
    </view>

    <!-- 快捷功能 -->
    <view class="quick-wrapper">
      <view class="quick-grid">
        <view class="quick-item" hover-class="tile-hover" data-type="album" bindtap="onQuick">
          <view class="icon-box">🖼️</view>
          <text class="quick-text">相册</text>
        </view>
        <view class="quick-item" hover-class="tile-hover" data-type="letter" bindtap="onQuick">
          <view class="icon-box">💌</view>
          <text class="quick-text">情书</text>
        </view>
        <view class="quick-item" hover-class="tile-hover" data-type="diary" bindtap="onQuick">
          <view class="icon-box">📒</view>
          <text class="quick-text">日记</text>
        </view>
        <view class="quick-item" hover-class="tile-hover" data-type="more" bindtap="onQuick">
          <view class="icon-box">📎</view>
          <text class="quick-text">更多</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 悬浮按钮 -->
  <view class="fab" hover-class="fab-hover" bindtap="onFab">🎈</view>
</view>
