/**app.wxss**/
/* app.wxss —— 全局推荐 */
page { 
  overflow-x: hidden;   /* 禁止横向滚动 */
}

/* 用基础组件集合代替 * 选择器 */
view, text, image, button, input, textarea, navigator, swiper, scroll-view {
  box-sizing: border-box;
  min-width: 0;         /* 防止 flex 子项被内容撑爆 */
}

.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
} 
