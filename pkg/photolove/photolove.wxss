page {
  background: #f8f2f5;
  color: #312b31;
}

.story-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.story-hero,
.composer,
.story-card,
.state-card,
.empty-card,
.notice {
  border-radius: 30rpx;
  box-sizing: border-box;
}

.story-hero {
  padding: 38rpx 32rpx;
  background: linear-gradient(135deg, #2f2a3d, #d58590);
  color: #fff;
  box-shadow: 0 16rpx 36rpx rgba(91, 47, 72, 0.2);
}

.title {
  display: block;
  font-size: 46rpx;
  font-weight: 900;
}

.subtitle,
.state-text,
.preview-text,
.preview-meta,
.story-text,
.story-meta {
  display: block;
  font-size: 25rpx;
  line-height: 1.55;
}

.story-hero button,
.primary,
.ghost,
.delete {
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 22rpx;
  border: 0;
  font-size: 27rpx;
  font-weight: 800;
  box-sizing: border-box;
}

.story-hero button,
.primary {
  margin-top: 22rpx;
  background: #ff7d92;
  color: #fff;
}

.composer,
.story-card,
.state-card,
.empty-card,
.notice {
  margin-top: 24rpx;
  padding: 26rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(91, 47, 72, 0.08);
}

.notice {
  color: #9c5e13;
  background: #fff1d8;
}

.preview-card {
  padding: 22rpx;
  border-radius: 26rpx;
  background: #fff7f8;
  border: 1rpx solid #f2ccd4;
}

.preview-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8rpx;
  height: 220rpx;
}

.preview-img {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
}

.preview-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 220rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #ffd1d8, #f6e2b8);
  color: #8c5363;
  font-weight: 800;
}

.preview-title,
.story-title,
.state-title,
.list-head {
  display: block;
  font-size: 32rpx;
  font-weight: 850;
}

.preview-title {
  margin-top: 18rpx;
}

.input,
.textarea,
.field {
  width: 100%;
  min-height: 82rpx;
  margin-top: 16rpx;
  padding: 0 22rpx;
  border-radius: 22rpx;
  background: #f8f2f5;
  box-sizing: border-box;
  font-size: 27rpx;
}

.textarea {
  min-height: 144rpx;
  padding-top: 20rpx;
}

.row,
.actions,
.story-head,
.list-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.row picker,
.place,
.actions button {
  flex: 1;
  min-width: 0;
}

.field {
  display: flex;
  align-items: center;
}

.picked-list,
.thumbs {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.picked {
  position: relative;
}

.picked image,
.thumbs image {
  width: 112rpx;
  height: 112rpx;
  border-radius: 18rpx;
}

.picked text {
  position: absolute;
  top: -10rpx;
  right: -10rpx;
  width: 34rpx;
  height: 34rpx;
  line-height: 34rpx;
  border-radius: 50%;
  background: #2f2a3d;
  color: #fff;
  text-align: center;
}

.ghost {
  background: #f3e8ed;
  color: #764e5e;
}

.list-head {
  justify-content: space-between;
  margin-top: 30rpx;
}

.empty-icon {
  display: block;
  font-size: 58rpx;
  margin-bottom: 8rpx;
}

.story-card {
  padding: 0;
  overflow: hidden;
}

.cover,
.text-cover {
  width: 100%;
  height: 340rpx;
}

.text-cover {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ffcad4, #f7e7b7);
  color: #fff;
  font-size: 60rpx;
  font-weight: 900;
}

.story-body {
  padding: 24rpx;
}

.story-head {
  justify-content: space-between;
}

.count {
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #f8f2f5;
  color: #8c6070;
  font-size: 22rpx;
}

.story-text {
  margin-top: 12rpx;
  color: #5d525b;
}

.delete {
  width: 100%;
  margin-top: 18rpx;
  background: #f3e8ed;
  color: #8c5363;
}
