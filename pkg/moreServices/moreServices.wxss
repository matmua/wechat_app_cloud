page {
  background: #f3f5f1;
  color: #2c332b;
}

.map-page {
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
}

.map-hero,
.section-card,
.route-card,
.bind-tip,
.notice {
  border-radius: 30rpx;
  box-sizing: border-box;
}

.map-hero {
  padding: 38rpx 32rpx;
  background: linear-gradient(135deg, #26352b, #8dae72);
  color: #fff;
  box-shadow: 0 16rpx 36rpx rgba(48, 73, 52, 0.2);
}

.eyebrow {
  display: block;
  font-size: 24rpx;
  opacity: 0.82;
}

.title {
  display: block;
  margin-top: 10rpx;
  font-size: 46rpx;
  font-weight: 900;
}

.subtitle,
.bind-tip,
.small-state,
.small-empty {
  display: block;
  font-size: 25rpx;
  line-height: 1.55;
}

.bind-tip,
.notice,
.section-card {
  margin-top: 24rpx;
  padding: 26rpx;
  background: #fff;
  box-shadow: 0 12rpx 28rpx rgba(48, 73, 52, 0.08);
}

.notice {
  color: #8a6216;
  background: #fff2d4;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 850;
  margin-bottom: 16rpx;
}

.feature {
  display: flex;
  gap: 14rpx;
  margin-top: 12rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #f3f5f1;
  font-size: 26rpx;
  line-height: 1.45;
}

.feature text:first-child {
  color: #5a8a53;
  font-weight: 900;
}

.route-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-top: 24rpx;
}

.route-card {
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-height: 104rpx;
  padding: 22rpx;
  background: #fff;
  box-shadow: 0 10rpx 24rpx rgba(48, 73, 52, 0.08);
  font-weight: 800;
}

.route-card text:first-child {
  font-size: 42rpx;
}

.textarea {
  width: 100%;
  min-height: 138rpx;
  padding: 20rpx 22rpx;
  border-radius: 24rpx;
  background: #f3f5f1;
  box-sizing: border-box;
  font-size: 27rpx;
}

.primary {
  width: 100%;
  height: 78rpx;
  line-height: 78rpx;
  margin-top: 18rpx;
  border-radius: 22rpx;
  border: 0;
  background: #26352b;
  color: #fff;
  font-size: 27rpx;
  font-weight: 800;
}

.feedback {
  margin-top: 16rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  background: #f3f5f1;
  font-size: 26rpx;
  line-height: 1.5;
}

.delete {
  display: block;
  margin-top: 8rpx;
  color: #b45a48;
  font-size: 24rpx;
}
