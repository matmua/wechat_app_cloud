page {
  background: #f3f7fb;
}

.assistant-page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  color: #26313d;
}

.assistant-hero {
  padding: 34rpx 30rpx;
  border-radius: 36rpx;
  background: #ffffff;
  border: 1rpx solid #dfe8f2;
}

.kicker,
.title,
.subtitle,
.mood-dot text,
.reply-label,
.reply-text,
.saved-item text {
  display: block;
}

.kicker {
  color: #5c78d6;
  font-size: 22rpx;
  font-weight: 900;
}

.title {
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 12rpx;
  color: #667383;
  font-size: 25rpx;
  line-height: 1.55;
}

.orbit {
  margin: 26rpx auto;
  width: 610rpx;
  min-height: 250rpx;
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 14rpx;
  align-items: center;
}

.mood-dot {
  height: 118rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  opacity: 0.72;
}

.mood-dot.active {
  opacity: 1;
  transform: translateY(-10rpx);
  box-shadow: 0 16rpx 28rpx rgba(38, 49, 61, 0.18);
}

.dot-pink { background: #ef6f9f; }
.dot-blue { background: #5c78d6; }
.dot-rose { background: #d95d72; }
.dot-amber { background: #e3a438; }
.dot-green { background: #43a886; }

.reply-card {
  padding: 30rpx;
  border-radius: 34rpx;
  color: #ffffff;
}

.card-pink { background: #ef6f9f; }
.card-blue { background: #5c78d6; }
.card-rose { background: #d95d72; }
.card-amber { background: #c98a20; }
.card-green { background: #34886f; }

.reply-label {
  font-size: 23rpx;
  font-weight: 900;
  opacity: 0.82;
}

.reply-text {
  margin-top: 18rpx;
  font-size: 32rpx;
  line-height: 1.45;
  font-weight: 900;
}

.copy-btn {
  margin-top: 26rpx;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.22);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}

.write-card {
  margin-top: 24rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid #dfe8f2;
}

.write-card textarea {
  width: 100%;
  min-height: 150rpx;
  padding: 18rpx;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #f3f7fb;
  font-size: 26rpx;
}

.write-card button {
  margin-top: 16rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 20rpx;
  background: #26313d;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 800;
}

.saved-list {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.saved-item {
  padding: 18rpx 20rpx;
  border-radius: 22rpx;
  background: #ffffff;
}

.saved-item text:first-child {
  color: #5c78d6;
  font-size: 22rpx;
  font-weight: 900;
}

.saved-item text:last-child {
  margin-top: 8rpx;
  color: #667383;
  font-size: 24rpx;
  line-height: 1.45;
}
