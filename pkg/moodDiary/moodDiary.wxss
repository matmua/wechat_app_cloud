page {
  background: #eef4ff;
}

.assistant-page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  color: #243044;
}

.assistant-hero {
  padding: 36rpx 30rpx;
  border-radius: 34rpx;
  background:
    linear-gradient(135deg, rgba(255,255,255,0.95), rgba(235,244,255,0.96)),
    linear-gradient(135deg, #8dc6ff, #ffd1dc);
  border: 1rpx solid #d9e7ff;
  box-shadow: 0 20rpx 42rpx rgba(49, 93, 153, 0.12);
}

.kicker,
.title,
.subtitle,
.config-pill text,
.quick-title,
.quick-desc,
.message-role,
.message-text,
.thinking text,
.chat-head text {
  display: block;
}

.kicker {
  color: #3977d8;
  font-size: 22rpx;
  font-weight: 800;
}

.title {
  margin-top: 10rpx;
  font-size: 50rpx;
  line-height: 1.15;
  font-weight: 900;
  letter-spacing: 0;
}

.subtitle {
  margin-top: 14rpx;
  color: #607086;
  font-size: 25rpx;
  line-height: 1.6;
}

.config-pill {
  margin-top: 22rpx;
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: #fff8df;
  color: #8a691e;
  font-size: 23rpx;
  line-height: 1.45;
}

.config-pill.ready {
  background: #eafaf2;
  color: #24724f;
}

.quick-scroll {
  margin: 26rpx -28rpx 0;
  white-space: nowrap;
}

.quick-track {
  display: flex;
  gap: 16rpx;
  padding: 0 28rpx 4rpx;
}

.quick-card {
  width: 218rpx;
  min-height: 128rpx;
  padding: 20rpx;
  border-radius: 28rpx;
  background: #ffffff;
  border: 1rpx solid #dce8fb;
  box-sizing: border-box;
  box-shadow: 0 12rpx 24rpx rgba(52, 86, 129, 0.08);
}

.quick-card.active {
  background: #28405f;
  color: #ffffff;
  border-color: #28405f;
}

.quick-title {
  font-size: 27rpx;
  font-weight: 900;
}

.quick-desc {
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.35;
  color: #71829a;
  white-space: normal;
}

.quick-card.active .quick-desc {
  color: rgba(255,255,255,0.78);
}

.chat-panel {
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid #dce8fb;
}

.chat-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.clear {
  color: #3977d8;
  font-size: 24rpx;
  font-weight: 700;
}

.message {
  margin-top: 16rpx;
  padding: 18rpx 20rpx;
  border-radius: 24rpx;
  background: #f3f7ff;
}

.message.user {
  margin-left: 66rpx;
  background: #28405f;
  color: #ffffff;
}

.message.assistant {
  margin-right: 44rpx;
}

.message.pending {
  background: #fff8df;
  color: #72591b;
}

.message-role {
  font-size: 21rpx;
  font-weight: 900;
  opacity: 0.7;
}

.message-text {
  margin-top: 8rpx;
  font-size: 27rpx;
  line-height: 1.55;
  word-break: break-word;
}

.thinking {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 20rpx;
  background: #eef4ff;
  color: #607086;
  font-size: 24rpx;
}

.composer {
  margin-top: 24rpx;
  padding: 22rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid #dce8fb;
  box-shadow: 0 16rpx 34rpx rgba(52, 86, 129, 0.08);
}

.composer-input {
  width: 100%;
  min-height: 126rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  box-sizing: border-box;
  background: #f3f7ff;
  color: #243044;
  font-size: 26rpx;
  line-height: 1.5;
}

.send-btn {
  margin-top: 18rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 24rpx;
  background: #3977d8;
  color: #ffffff;
  font-size: 27rpx;
  font-weight: 900;
}
