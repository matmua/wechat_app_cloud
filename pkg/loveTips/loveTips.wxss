page {
  background: #eef8fb;
}

.call-page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  color: #21333a;
}

.radar-card {
  position: relative;
  overflow: hidden;
  min-height: 420rpx;
  padding: 34rpx 30rpx;
  border-radius: 36rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #17424e, #2aa6a1);
  box-shadow: 0 20rpx 44rpx rgba(24, 80, 90, 0.22);
}

.kicker,
.title,
.signal,
.level,
.message-title,
.message-text,
.note {
  display: block;
}

.kicker {
  font-size: 22rpx;
  opacity: 0.8;
  font-weight: 700;
}

.title {
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 900;
}

.radar {
  position: absolute;
  right: -36rpx;
  bottom: -46rpx;
  width: 330rpx;
  height: 330rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
}

.ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(255, 255, 255, 0.28);
}

.ring-one { inset: 44rpx; }
.ring-two { inset: 92rpx; }
.ring-three { inset: 138rpx; }

.dot {
  position: absolute;
  left: 112rpx;
  top: 82rpx;
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #ffe66d;
  box-shadow: 0 0 26rpx rgba(255, 230, 109, 0.8);
}

.signal {
  position: absolute;
  left: 30rpx;
  bottom: 34rpx;
  font-size: 28rpx;
  font-weight: 800;
}

.message-card {
  margin-top: 26rpx;
  padding: 30rpx;
  border-radius: 34rpx;
  background: #ffffff;
  border: 1rpx solid #d5edf1;
}

.level {
  color: #1b9a96;
  font-size: 23rpx;
  font-weight: 900;
}

.message-title {
  margin-top: 14rpx;
  font-size: 36rpx;
  font-weight: 900;
}

.message-text {
  margin-top: 16rpx;
  color: #50646b;
  font-size: 28rpx;
  line-height: 1.55;
}

.actions {
  margin-top: 26rpx;
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 800;
}

.btn.dark {
  background: #21333a;
  color: #ffffff;
}

.btn.light {
  background: #dff5f5;
  color: #157e7a;
}

.call-strip {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.call-chip {
  padding: 18rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid #d5edf1;
}

.call-chip text {
  display: block;
}

.call-chip text:first-child {
  font-size: 26rpx;
  font-weight: 900;
}

.call-chip text:last-child {
  margin-top: 8rpx;
  color: #6a8087;
  font-size: 22rpx;
}

.call-chip.active {
  background: #17424e;
  color: #ffffff;
}

.call-chip.active text:last-child {
  color: rgba(255, 255, 255, 0.72);
}

.note {
  margin: 24rpx 8rpx 0;
  color: #688087;
  font-size: 23rpx;
  line-height: 1.5;
}
