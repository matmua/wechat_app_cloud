page {
  background: #171923;
}

.arcade-page {
  min-height: 100vh;
  padding: 28rpx;
  box-sizing: border-box;
  color: #f8fbff;
}

.arcade-hero {
  padding: 34rpx 30rpx;
  border-radius: 18rpx;
  background: #242838;
  border: 3rpx solid #4a5268;
  box-shadow: 0 18rpx 0 #0e1018;
}

.kicker,
.title,
.subtitle,
.cassette text,
.screen-top text,
.message,
.coming text {
  display: block;
}

.kicker {
  color: #53f0c6;
  font-size: 22rpx;
  font-weight: 900;
}

.title {
  margin-top: 10rpx;
  color: #ffd166;
  font-size: 50rpx;
  font-weight: 900;
}

.subtitle {
  margin-top: 12rpx;
  color: #aeb7c9;
  font-size: 25rpx;
  line-height: 1.5;
}

.cassette-wall {
  margin-top: 30rpx;
  white-space: nowrap;
}

.cassette {
  display: inline-block;
  width: 240rpx;
  min-height: 180rpx;
  margin-right: 16rpx;
  padding: 20rpx;
  border-radius: 18rpx;
  background: #30364a;
  border: 3rpx solid #566079;
  vertical-align: top;
}

.cassette.active {
  background: #ff5d7a;
  border-color: #ffd166;
}

.cassette text:first-child {
  color: #ffd166;
  font-size: 20rpx;
  font-weight: 900;
}

.cassette text:nth-child(2) {
  margin-top: 10rpx;
  font-size: 32rpx;
  font-weight: 900;
}

.cassette text:last-child {
  margin-top: 10rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 22rpx;
  line-height: 1.35;
  white-space: normal;
}

.machine {
  margin-top: 28rpx;
  padding: 24rpx;
  border-radius: 34rpx;
  background: #d74e67;
  box-shadow: inset 0 -10rpx 0 rgba(0, 0, 0, 0.18), 0 20rpx 36rpx rgba(0, 0, 0, 0.26);
}

.screen {
  padding: 18rpx;
  border-radius: 24rpx;
  background: #0b1020;
  border: 8rpx solid #2a2f42;
}

.screen-top {
  display: flex;
  justify-content: space-between;
  color: #53f0c6;
  font-size: 24rpx;
  font-weight: 900;
}

.snake-board {
  margin: 18rpx auto 0;
  width: 600rpx;
  height: 600rpx;
  display: grid;
  grid-template-columns: repeat(10, 1fr);
  grid-template-rows: repeat(10, 1fr);
  gap: 4rpx;
}

.cell {
  border-radius: 8rpx;
  background: #161d33;
}

.cell.snake {
  background: #53f0c6;
}

.cell.head {
  background: #ffd166;
}

.cell.food {
  background: #ff5d7a;
  box-shadow: 0 0 16rpx rgba(255, 93, 122, 0.9);
}

.message {
  margin-top: 16rpx;
  color: #f8fbff;
  font-size: 24rpx;
  text-align: center;
}

.controls {
  margin-top: 24rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 14rpx;
}

.controls button {
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 18rpx;
  background: #242838;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  border: 2rpx solid #566079;
}

.controls button.start {
  background: #ffd166;
  color: #171923;
}

.coming {
  margin-top: 26rpx;
  padding: 24rpx;
  border-radius: 22rpx;
  background: #242838;
  border: 2rpx solid #4a5268;
}

.coming text:first-child {
  color: #ffd166;
  font-size: 28rpx;
  font-weight: 900;
}

.coming text:last-child {
  margin-top: 8rpx;
  color: #aeb7c9;
  font-size: 24rpx;
  line-height: 1.45;
}
