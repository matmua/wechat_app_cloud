page {
  background: #eaf5ff;
  overflow-x: hidden;
}

.weather-page {
  min-height: 100vh;
  width: 100%;
  padding: 28rpx;
  box-sizing: border-box;
  color: #243140;
  overflow-x: hidden;
}

.sky-hero {
  position: relative;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
  padding: 36rpx 30rpx;
  border-radius: 36rpx;
  color: #ffffff;
  background: linear-gradient(145deg, #4d8cf7, #75d3f2);
}

.sky-hero::after {
  content: "";
  position: absolute;
  right: -40rpx;
  top: 40rpx;
  width: 210rpx;
  height: 86rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.38);
  box-shadow: -90rpx 38rpx 0 rgba(255, 255, 255, 0.25);
}

.kicker,
.title,
.subtitle,
.state-card text,
.card-label,
.city,
.updated,
.weather-line text,
.care-tip,
.api-note,
.waiting-title,
.waiting-text,
.section-title,
.privacy,
.mine,
.error {
  display: block;
}

.kicker {
  font-size: 22rpx;
  font-weight: 900;
  opacity: 0.84;
}

.title {
  margin-top: 10rpx;
  font-size: 50rpx;
  font-weight: 900;
}

.subtitle {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
  max-width: 520rpx;
  font-size: 25rpx;
  line-height: 1.55;
}

.state-card,
.remote-card,
.waiting-card,
.sync-card,
.error {
  margin-top: 24rpx;
  padding: 26rpx;
  border-radius: 30rpx;
  background: #ffffff;
  border: 1rpx solid #d7e9fb;
}

.state-card text:first-child {
  font-size: 30rpx;
  font-weight: 900;
}

.state-card text:last-child {
  margin-top: 10rpx;
  color: #68798b;
  font-size: 24rpx;
}

.remote-card {
  min-height: 320rpx;
  background: linear-gradient(160deg, #ffffff, #f3f9ff);
  box-shadow: 0 18rpx 38rpx rgba(68, 121, 180, 0.13);
}

.weather-grid {
  width: 100%;
  margin-top: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 22rpx;
  box-sizing: border-box;
}

.weather-grid .remote-card,
.weather-grid .waiting-card {
  margin-top: 0;
}

.self-card {
  background: linear-gradient(160deg, #ffffff, #f2fbf8);
}

.partner-card {
  background: linear-gradient(160deg, #ffffff, #f3f9ff);
}

.card-label {
  margin-bottom: 18rpx;
  color: #2f79df;
  font-size: 24rpx;
  font-weight: 900;
}

.self-card .card-label {
  color: #1d9d7a;
}

.remote-top {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
}

.city {
  font-size: 42rpx;
  font-weight: 900;
}

.updated {
  margin-top: 8rpx;
  color: #76889a;
  font-size: 23rpx;
}

.temp {
  font-size: 82rpx;
  line-height: 1;
  color: #2f79df;
  font-weight: 900;
}

.weather-line {
  margin-top: 32rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.weather-line text {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: #e8f3ff;
  color: #2f79df;
  font-size: 25rpx;
  font-weight: 900;
}

.care-tip {
  margin-top: 26rpx;
  padding: 22rpx;
  border-radius: 24rpx;
  background: #fff4d9;
  color: #8b6518;
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.45;
}

.weather-detail {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.weather-detail text {
  padding: 10rpx 16rpx;
  border-radius: 16rpx;
  background: #f4f9ff;
  color: #5f7186;
  font-size: 23rpx;
}

.api-note,
.privacy,
.mine {
  margin-top: 16rpx;
  color: #718294;
  font-size: 23rpx;
  line-height: 1.5;
}

.mine.ok {
  color: #1d9d7a;
  font-weight: 900;
}

.mine.warn {
  color: #c77a13;
  font-weight: 900;
}

.waiting-title,
.section-title {
  font-size: 32rpx;
  font-weight: 900;
}

.compact {
  min-height: 0;
}

.waiting-text {
  margin-top: 10rpx;
  color: #718294;
  font-size: 25rpx;
  line-height: 1.55;
}

.waiting-card button,
.error button {
  width: 100%;
  margin: 18rpx 0 0;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 16rpx;
  border-radius: 18rpx;
  background: #2f79df;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.waiting-card button::after,
.error button::after,
.location-actions button::after,
.sync-btn::after {
  border: 0;
}

.city-row,
.location-actions {
  margin-top: 18rpx;
  display: grid;
  gap: 14rpx;
  box-sizing: border-box;
}

.city-row {
  grid-template-columns: 1fr;
}

.location-actions {
  grid-template-columns: repeat(2, minmax(0, 1fr));
}

.city-row input {
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 20rpx;
  background: #eef7ff;
  font-size: 26rpx;
}

.location-actions button,
.sync-btn {
  width: 100%;
  margin: 0;
  height: 76rpx;
  line-height: 76rpx;
  padding: 0 12rpx;
  border-radius: 20rpx;
  background: #2f79df;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 900;
  box-sizing: border-box;
}

.location-actions button.ghost {
  background: #e8f3ff;
  color: #2f79df;
}

.sync-btn {
  margin: 16rpx 0 0;
}

.error {
  color: #c54a5f;
  font-size: 24rpx;
}

.error text {
  display: block;
  line-height: 1.45;
}
